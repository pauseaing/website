---
const today = new Date();
---

<footer>
	<div class="container-root footer-inner">
		<div>
			<p>&copy; {today.getFullYear()} PauseAI Nigeria. All rights reserved.</p>
			<p class="contact-line">Contact: <a href="mailto:nigeria@pauseai.info">nigeria@pauseai.info</a></p>
		</div>
		<div class="quick-links" aria-label="Footer links">
			<a href="/privacy">Privacy</a>
			<a href="/resources">Resources</a>
			<a href="/nigeria-ai-policy">Policy Tracker</a>
		</div>
		<div class="social-links" aria-label="Social links coming soon">
			<span>X (coming soon)</span>
			<span>LinkedIn (coming soon)</span>
			<span>WhatsApp (coming soon)</span>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: var(--space-4) 0;
		background: var(--surface-1);
		border-top: 1px solid var(--border-subtle);
		color: var(--text-muted);
		text-align: center;
	}
	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
		flex-wrap: wrap;
	}
	.footer-inner p {
		margin: 0;
	}
	.contact-line {
		margin-top: 0.4rem;
	}
	.quick-links {
		display: flex;
		gap: 1rem;
	}
	.social-links {
		display: flex;
		gap: 0.7rem;
		font-size: 0.85rem;
	}
	.social-links span {
		display: inline-flex;
		align-items: center;
	}
	a:hover {
		color: var(--brand-orange);
	}
	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
		}
		.quick-links {
			flex-wrap: wrap;
		}
	}
</style>
