---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/why-pause">Why Pause AI?</HeaderLink>
			<HeaderLink href="/take-action">Take Action</HeaderLink>
			<HeaderLink href="/events">Events</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About Us</HeaderLink>
			<HeaderLink href="/nigeria-ai-policy">Policy Tracker</HeaderLink>
			<HeaderLink href="/communities">Communities</HeaderLink>
			<HeaderLink href="/resources">Resources</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
		<button id="theme-toggle" class="btn-root btn-secondary" type="button">Theme</button>
		<div class="social-links" aria-label="Social links coming soon">
			<span>X (coming soon)</span>
			<span>LinkedIn (coming soon)</span>
			<span>WhatsApp (coming soon)</span>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 var(--space-2);
		background: var(--surface-1);
		border-bottom: 1px solid var(--border-subtle);
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		flex-wrap: wrap;
	}
	h2 {
		margin: 0;
		font-size: 1.1rem;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-2);
		min-height: 72px;
	}
	nav a {
		padding: 0.4em 0.5em;
		color: var(--text-body);
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--brand-orange);
		color: var(--brand-orange);
	}
	.social-links,
	.social-links span {
		display: flex;
		align-items: center;
	}
	.social-links {
		gap: 0.4rem;
		font-size: 0.82rem;
		color: var(--text-muted);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		nav {
			align-items: flex-start;
			padding: var(--space-1) 0;
		}
		h2 {
			padding-top: 0.6rem;
		}
		#theme-toggle {
			margin-top: 0.45rem;
		}
	}
</style>

<script is:inline>
	const root = document.documentElement;
	const key = 'pauseai-theme';
	const stored = localStorage.getItem(key);
	if (stored === 'dark' || stored === 'light') {
		root.setAttribute('data-theme', stored);
	}

	const toggle = document.getElementById('theme-toggle');
	toggle?.addEventListener('click', () => {
		const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
		root.setAttribute('data-theme', next);
		localStorage.setItem(key, next);
	});
</script>
