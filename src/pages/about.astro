---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
	title="About PauseAI Nigeria"
	description="Who we are, why this chapter was formed, and how to work with PauseAI Nigeria."
>
	<section class="section-root">
		<div class="container-root">
			<h1>About PauseAI Nigeria</h1>
			<p>
				PauseAI Nigeria was founded by a small group of organizers, researchers, and technology professionals
				who saw a widening gap between the pace of frontier AI development and the pace of public accountability.
				We formed this chapter because Nigeria should not wait for external institutions to define AI risk policy
				on our behalf.
			</p>
			<p>
				As the first West Africa chapter in PauseAI Global, we work to translate global AI safety concerns into
				a credible Nigerian policy agenda. Our mission is to build public understanding, support evidence-based
				law and regulation, and organize practical civic action so that powerful AI systems are governed by safety,
				democratic oversight, and public interest.
			</p>
		</div>
	</section>

	<section id="team" class="section-root section-root-accent">
		<div class="container-root">
			<h2>Founding Team</h2>
			<p>Team profiles are editable via CMS and will expand as city organizers come onboard.</p>
			<div class="team-grid">
				{
					team.length > 0 ? (
						team.map((member) => (
							<article class="card-root card-pad team-card">
								{
									member.data.photo ? (
										<Image
											src={member.data.photo}
											alt={`${member.data.name} photo`}
											width={320}
											height={320}
											class="team-photo"
										/>
									) : (
										<div class="team-photo team-photo-fallback" aria-hidden="true"></div>
									)
								}
								<div class="team-card-body">
									<h3 class="team-name">{member.data.name}</h3>
								<p><strong>{member.data.role}</strong></p>
									<p>{member.data.bio}</p>
								</div>
								<div class="team-links" aria-label={`Contact links for ${member.data.name}`}>
									<a href={`mailto:${member.data.email}`} aria-label={`Email ${member.data.name}`}>
										<i class="ri-mail-line" aria-hidden="true"></i>
									</a>
									<a href={member.data.linkedin} target="_blank" rel="noreferrer" aria-label={`${member.data.name} LinkedIn`}>
										<i class="ri-linkedin-box-line" aria-hidden="true"></i>
									</a>
								</div>
							</article>
						))
					) : (
						<article class="card-root card-pad">
							<h3>Team directory</h3>
							<p>Chapter team profiles are maintained in the CMS and published here automatically.</p>
						</article>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-root">
		<div class="container-root">
			<h2>Chapter Timeline</h2>
			<ul class="timeline">
				<li>Founding chapter coordination began in early 2026.</li>
				<li>Initial policy and organizing roadmap drafted across Lagos and Abuja networks.</li>
				<li>Public chapter rollout and volunteer expansion in progress.</li>
				<li>Legal registration and formal governance structure in progress.</li>
			</ul>
		</div>
	</section>

	<section id="press" class="section-root section-root-accent">
		<div class="container-root">
			<h2>Press and Media</h2>
			<p>For interviews and statements, contact <a href="mailto:nigeria@pauseai.info">nigeria@pauseai.info</a>.</p>
			<p>Response target: within 48 hours.</p>
		</div>
	</section>
</BaseLayout>

<style>
	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-2);
		margin-top: var(--space-2);
	}
	.card-pad {
		padding: var(--space-2);
	}
	.team-card {
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	.team-photo {
		width: 100%;
		aspect-ratio: 3 / 4;
		object-fit: cover;
		border-radius: 0;
		margin-bottom: var(--space-1);
		border: 1px solid var(--border-color);
	}
	.team-photo-fallback {
		background: linear-gradient(145deg, color-mix(in srgb, var(--brand-green) 22%, white), white);
	}
	.team-card-body {
		flex: 1;
	}
	.team-name {
		color: var(--brand-orange);
		margin-bottom: 0.35rem;
	}
	.team-links {
		display: flex;
		gap: 0.7rem;
		margin-top: var(--space-2);
	}
	.team-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border: 1px solid var(--border-color);
		border-radius: 999px;
		color: var(--brand-orange);
		text-decoration: none;
	}
	.team-links a:hover {
		border-color: var(--brand-orange);
		background: color-mix(in srgb, var(--brand-orange) 10%, white);
	}
	.timeline {
		margin: var(--space-2) 0 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.6rem;
	}
</style>
