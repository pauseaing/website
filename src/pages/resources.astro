---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resources"
  description="Curated reading, videos, and policy references on AI safety and governance."
>
  <section class="section-root">
    <div class="container-root">
      <h1>Resources and Reading List</h1>
      <p>Curated materials for students, journalists, policymakers, and civil society leaders.</p>
    </div>
  </section>

  <section class="section-root section-root-accent">
    <div class="container-root">
      <h2>Essential Reads</h2>
      <ul>
        <li><a href="https://www.safe.ai/statement-on-ai-risk" target="_blank" rel="noreferrer">Statement on AI Risk</a></li>
        <li><a href="https://pauseai.info/proposal" target="_blank" rel="noreferrer">PauseAI proposal</a></li>
      </ul>
    </div>
  </section>

  <section class="section-root">
    <div class="container-root">
      <h2>Nigerian Context</h2>
      <ul>
        <li><a href="https://nitda.gov.ng" target="_blank" rel="noreferrer">NITDA resources</a></li>
        <li><a href="https://ncc.gov.ng" target="_blank" rel="noreferrer">NCC resources</a></li>
      </ul>
    </div>
  </section>

  <section class="section-root section-root-accent">
    <div class="container-root">
      <h2>For Policymakers</h2>
      <p>Formal briefing links and position paper downloads will be published here.</p>
    </div>
  </section>
</BaseLayout>
