---

<footer>
	<div class="container-root footer-inner">
		<div>
			<p>&copy; <span id="footer-year"></span> PauseAI Nigeria. All rights reserved.</p>
			<p class="contact-line">Contact: <a href="mailto:nigeria@pauseai.info">nigeria@pauseai.info</a></p>
		</div>
		<div class="quick-links" aria-label="Footer links">
			<a href="/privacy">Privacy</a>
			<a href="/resources">Resources</a>
			<a href="/nigeria-ai-policy">Policy Tracker</a>
		</div>
		<div class="social-links" aria-label="Social links">
			<a href="https://chat.whatsapp.com/L4o2IiOX1HI2GWQi0J9ZJv" target="_blank" rel="noreferrer" aria-label="Join on WhatsApp">
				<i class="ri-whatsapp-line" aria-hidden="true"></i>
				<span>WhatsApp</span>
			</a>
			<a href="https://www.linkedin.com/company/pauseai-nigeria/" target="_blank" rel="noreferrer" aria-label="Follow on LinkedIn">
				<i class="ri-linkedin-box-line" aria-hidden="true"></i>
				<span>LinkedIn</span>
			</a>
			<a href="https://www.facebook.com/profile.php?id=61585704817897&mibextid=wwXIfr&mibextid=wwXIfr" target="_blank" rel="noreferrer" aria-label="Follow on Facebook">
				<i class="ri-facebook-circle-line" aria-hidden="true"></i>
				<span>Facebook</span>
			</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: var(--space-4) 0;
		background: var(--surface-1);
		border-top: 1px solid var(--border-subtle);
		color: var(--text-muted);
		text-align: center;
	}
	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3);
		flex-wrap: wrap;
	}
	.footer-inner p {
		margin: 0;
	}
	.contact-line {
		margin-top: 0.4rem;
	}
	.quick-links {
		display: flex;
		gap: 1rem;
	}
	.social-links {
		display: flex;
		gap: 0.7rem;
		font-size: 0.85rem;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		text-decoration: none;
		color: var(--text-muted);
	}
	.social-links i {
		font-size: 1.05rem;
		color: var(--brand-green);
	}
	a:hover {
		color: var(--brand-orange);
	}
	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			align-items: flex-start;
		}
		.quick-links {
			flex-wrap: wrap;
		}
	}
</style>

<script is:inline>
	const footerYear = document.getElementById('footer-year');
	if (footerYear) {
		footerYear.textContent = String(new Date().getFullYear());
	}
</script>
