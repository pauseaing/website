---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
	title="About PauseAI Nigeria"
	description="Who we are, why this chapter was formed, and how to work with PauseAI Nigeria."
>
	<section class="section-root">
		<div class="container-root">
			<h1>About PauseAI Nigeria</h1>
			<p>
				PauseAI Nigeria was founded by organizers, researchers, and technology professionals who recognized a critical gap:
				frontier AI is being developed faster than safety can be guaranteed or democratic institutions can respond. We formed
				this chapter because Nigeria must not be sidelined in decisions that affect humanity's AI future.
			</p>
			<p>
				As the first PauseAI chapter in West Africa, we contribute to a global movement calling for a temporary pause on
				training the most powerful AI systems until robust safety guarantees and meaningful democratic oversight are in place.
			</p>
			<p>
				Our mission is to:
			</p>
			<ul style="margin: var(--space-1) 0; padding-left: 1.5rem;">
				<li><strong>Build public awareness</strong> of AI risks and why democratic control matters</li>
				<li><strong>Inform policy discourse</strong> through evidence-based research and expert voices</li>
				<li><strong>Engage policymakers</strong> to ensure Nigeria participates in international AI governance</li>
				<li><strong>Mobilize civic action</strong>—protests, campaigns, and direct advocacy—to shift political will</li>
				<li><strong>Engage students and youth</strong> as future leaders and technologists who will inherit these systems</li>
			</ul>
			<p>
				This is not anti-technology. It is pro-democracy. We believe Nigeria can lead on AI safety while remaining an innovation
				hub. Responsible governance comes first; progress follows.
			</p>
		</div>
	</section>

	<section id="team" class="section-root section-root-accent">
		<div class="container-root">
			<h2>Founding Team</h2>
			<p>Team profiles are editable via CMS and will expand as city organizers come onboard.</p>
			<div class="team-grid">
				{
					team.length > 0 ? (
						team.map((member) => (
							<article class="card-root card-pad team-card">
								{
									member.data.photo ? (
										<Image
											src={member.data.photo}
											alt={`${member.data.name} photo`}
											width={320}
											height={320}
											class="team-photo"
										/>
									) : (
										<div class="team-photo team-photo-fallback" aria-hidden="true"></div>
									)
								}
								<div class="team-card-body">
									<h3 class="team-name">{member.data.name}</h3>
								<p><strong class="team-role">{member.data.role}</strong></p>
									<p>{member.data.bio}</p>
								</div>
								<div class="team-links" aria-label={`Contact links for ${member.data.name}`}>
									{member.data.email && (
										<a href={`mailto:${member.data.email}`} aria-label={`Email ${member.data.name}`}>
											<i class="ri-mail-line" aria-hidden="true"></i>
										</a>
									)}
									<a href={member.data.linkedin} target="_blank" rel="noreferrer" aria-label={`${member.data.name} LinkedIn`}>
										<i class="ri-linkedin-box-line" aria-hidden="true"></i>
									</a>
								</div>
							</article>
						))
					) : (
						<article class="card-root card-pad">
							<h3>Team directory</h3>
							<p>Chapter team profiles are maintained in the CMS and published here automatically.</p>
						</article>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-root">
		<div class="container-root">
		<h2>Our Approach</h2>
		<p>
			We operate with five core strategies, grounded in the broader PauseAI Global theory of change:
		</p>
		<ul class="timeline">
			<li><strong>Grow the Movement:</strong> Build a national volunteer base through online organizing, accessible ways to take action, and transparent communication.</li>
			<li><strong>Inform Public Discourse:</strong> Publish educational content, appear in media, host events, and partner with academics and civil society to shift the conversation.</li>
			<li><strong>Engage Policymakers:</strong> Direct lobbying, policy briefs, and meetings with legislators and regulators to raise AI safety to decision-making priority.</li>
			<li><strong>Organize Civic Action:</strong> Coordinate protests, campaigns, and public pressure to shift political will and media attention.</li>
			<li><strong>Mobilize Youth:</strong> Host university debates, engage students as future leaders, and build a pipeline of informed AI safety advocates.</li>
		</ul>
		<p style="margin-top: var(--space-2); color: var(--text-muted);">
			For full context, see the <a href="/" style="text-decoration: underline;">PauseAI Global Theory of Change</a>.
		</p>
		</div>
	</section>

	<section id="press" class="section-root section-root-accent">
		<div class="container-root">
			<h2>Press and Media</h2>
			<p>For interviews and statements, contact <a href="mailto:nigeria@pauseai.info">nigeria@pauseai.info</a>.</p>
			<p>Response target: within 48 hours.</p>
		</div>
	</section>
</BaseLayout>

<style>
	.team-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		column-gap: var(--space-2);
		row-gap: var(--space-5);
		margin-top: var(--space-2);
	}
	.card-pad {
		padding: var(--space-2);
	}
	.team-card {
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	.team-photo {
		width: 100%;
		aspect-ratio: 3 / 4;
		object-fit: cover;
		border-radius: 0;
		margin-bottom: var(--space-1);
		border: 1px solid var(--border-color);
	}
	.team-photo-fallback {
		background: linear-gradient(145deg, color-mix(in srgb, var(--brand-green) 22%, white), white);
	}
	.team-card-body {
		flex: 1;
	}
	.team-name {
		color: var(--brand-orange);
		margin-bottom: 0.35rem;
	}
	.team-role {
		color: var(--brand-green);
	}
	.team-links {
		display: flex;
		gap: 0.7rem;
		margin-top: var(--space-2);
	}
	.team-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border: 1px solid var(--border-color);
		border-radius: 999px;
		color: var(--brand-orange);
		text-decoration: none;
	}
	.team-links a:hover {
		border-color: var(--brand-orange);
		background: color-mix(in srgb, var(--brand-orange) 10%, white);
	}
	.timeline {
		margin: var(--space-2) 0 0;
		padding-left: 1.2rem;
		display: grid;
		gap: 0.6rem;
	}
	@media (max-width: 720px) {
		.team-grid {
			row-gap: var(--space-4);
		}
	}
</style>
