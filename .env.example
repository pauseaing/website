# PauseAI Nigeria Environment Variables
# Copy this file to .env.local and fill in actual values for deployment

# Site Configuration
PUBLIC_SITE_URL=https://pauseai.ng

# Brevo Newsletter (Optional for V1; set up later if needed)
# BREVO_API_KEY=your_brevo_api_key_here
# BREVO_LIST_ID=your_brevo_list_id_here

# Analytics (Optional for V1; configure in script if using Plausible)
# PUBLIC_PLAUSIBLE_DOMAIN=pauseai.ng

# Netlify Forms
# Forms are automatically captured via data-netlify="true" attribute
# Submissions appear in Netlify dashboard under Site settings > Forms

# Build Flags
NODE_ENV=production
