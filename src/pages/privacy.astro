---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="How PauseAI Nigeria collects and uses information through this website."
>
  <section class="section-root">
    <div class="container-root">
      <h1>Privacy Policy</h1>
      <p>Effective date: April 2026</p>
      <p>
        PauseAI Nigeria collects only the data needed to manage communications, volunteer coordination,
        and chapter updates.
      </p>
    </div>
  </section>

  <section class="section-root section-root-accent">
    <div class="container-root">
      <h2>Information We Collect</h2>
      <ul>
        <li>Contact details submitted through forms (name, email, city, and message content).</li>
        <li>Newsletter opt-in data when you subscribe.</li>
        <li>Basic website analytics where enabled.</li>
      </ul>
    </div>
  </section>

  <section class="section-root">
    <div class="container-root">
      <h2>How We Use Information</h2>
      <ul>
        <li>To respond to enquiries and coordinate chapter activities.</li>
        <li>To send periodic updates if you have opted in.</li>
        <li>To improve site content and accessibility.</li>
      </ul>
      <p>We do not sell personal data.</p>
    </div>
  </section>

  <section class="section-root section-root-accent">
    <div class="container-root">
      <h2>Your Rights and Contact</h2>
      <p>
        You can request deletion or correction of your submitted data by contacting
        <a href="mailto:nigeria@pauseai.info">nigeria@pauseai.info</a>.
      </p>
    </div>
  </section>
</BaseLayout>
